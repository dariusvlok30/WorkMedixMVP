# WorkMedix API base URL (your deployed app or local dev server)
WORKMEDIX_API_URL=https://your-workmedix-app.vercel.app

# Shared secret — must match BRIDGE_SECRET in your WorkMedix environment
BRIDGE_SECRET=change-me-to-a-random-string

# WebSocket port — the clinic page connects to ws://localhost:PORT
WS_PORT=3001

# Serial port paths for each device (Windows: COM3, COM4 etc. Linux/Mac: /dev/ttyUSB0)
SPIROMETER_PORT=COM3
AUDIOMETER_PORT=COM4
